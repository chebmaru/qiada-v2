# Database
DATABASE_URL=postgresql://qiada:qiada_dev@localhost:5432/qiada_v2

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@qiada.app

# TTS (opzionale — fallback a Web Speech API)
# Nessuna chiave necessaria per Microsoft Edge Neural (gratis)

# DeepSeek (per pipeline traduzione)
DEEPSEEK_API_KEY=

# Admin
ADMIN_EMAIL=admin@qiada.app
ADMIN_PASSWORD=change-me
